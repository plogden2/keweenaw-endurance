# Copy to .env.prod and adjust for local prod-like smoke or deployment.
# docker compose -f docker-compose.prod.yml --env-file .env.prod up --build -d

JWT_SECRET=change-me-in-production
DB_PASSWORD=timing_pass
ORGANIZER_PIN=1738

DATA_DIR=/app/data
LIVE_CSV_MIRROR_DIR=/app/csv-mirror

# Optional: GCS bucket for live CSV mirror (Task 5+); leave empty for local volume only
GCS_LIVE_CSV_BUCKET=

# Optional: token for bridge ingest when using hosted scoring path
BRIDGE_TOKEN=
BRIDGE_DEVICE_ID=laptop-finish-1

CORS_ORIGINS=http://keweenawendurance.com,http://localhost
